# EventGuard Environment Configuration
# Copy this file to .env and fill in values as needed.

# ── Encryption ───────────────────────────────────────────────────
# Key used for AES encryption of biometric data. Set a strong random string.
EVENTGUARD_ENCRYPTION_KEY=change-me-to-a-strong-random-key

# ── Dashboard Authentication ─────────────────────────────────────
# Leave blank to disable authentication.
EG_DASHBOARD_USERNAME=admin
EG_DASHBOARD_PASSWORD=

# ── CV Tuning ────────────────────────────────────────────────────
# EG_EYE_AR_THRESH=0.23
# EG_EYE_AR_CONSEC_FRAMES=2
# EG_FRAME_RESIZE_SCALE=0.25
# EG_TOLERANCE=0.5

# ── Liveness Detection ──────────────────────────────────────────
# EG_MOUTH_AR_THRESH=0.6
# EG_HEAD_POSE_YAW_THRESH=15.0
# EG_CHALLENGE_TIMEOUT=10

# ── Logging ──────────────────────────────────────────────────────
# EG_LOG_LEVEL=INFO
